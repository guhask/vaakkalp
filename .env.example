# Google AI / ADK — get from: https://aistudio.google.com/apikey (free, instant)
GOOGLE_API_KEY=your_google_api_key_here

# Google Cloud — get from: https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_REGION=asia-south1

# Google Cloud Storage bucket (create in GCP console)
GCS_BUCKET_NAME=vaakkalp-archives

# App
APP_ENV=development
LOG_LEVEL=INFO
